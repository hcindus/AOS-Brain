# Lead Enrichment Pipeline - API Keys
# Copy this file to .env and fill in your actual API keys

# Hunter.io - Email finder (https://hunter.io/api)
# Free tier: 25 searches/month, 50 verifications/month
HUNTER_API_KEY=your_hunter_api_key_here

# Clearbit - Company data enrichment (https://clearbit.com/docs#authentication)
# Free tier: 20 requests/month
CLEARBIT_API_KEY=your_clearbit_api_key_here

# Brave Search API - Web search (https://brave.com/search/api/)
# Free tier: 2,000 queries/month
BRAVE_API_KEY=your_brave_api_key_here

# Serper.dev - Google Search API (https://serper.dev/)
# Free tier: 2,500 queries
SERPER_API_KEY=your_serper_api_key_here

# Optional: Rate limiting configuration
# RATE_LIMIT_DELAY=1.0
# MAX_RETRIES=3
