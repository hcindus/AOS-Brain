<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AGI Company | myl0nr0s.cloud</title>
    <style>
        :root {
            --primary: #004080;
            --secondary: #ff6600;
            --success: #28a745;
            --danger: #dc3545;
            --dark: #0a1628;
            --bg-dark: rgba(10, 22, 40, 0.85);
            --border: rgba(255,255,255,0.1);
            --text: #e5e5e5;
            --text-muted: rgba(255,255,255,0.6);
        }
        
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Segoe UI', -apple-system, sans-serif;
            background: var(--dark);
            color: var(--text);
            min-height: 100vh;
        }
        
        a { text-decoration: none; color: inherit; }
        
        /* Top Bar */
        .top-bar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: 60px;
            background: var(--bg-dark);
            backdrop-filter: blur(10px);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 30px;
            z-index: 100;
            border-bottom: 1px solid var(--border);
        }
        
        .top-bar-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 20px;
            font-weight: 700;
            color: white;
        }
        
        .top-bar-nav {
            display: flex;
            gap: 5px;
        }
        
        .top-bar-nav a {
            padding: 10px 16px;
            color: var(--text-muted);
            font-size: 14px;
            border-radius: 6px;
            transition: all 0.3s;
        }
        
        .top-bar-nav a:hover, .top-bar-nav a.active {
            color: white;
            background: rgba(255,255,255,0.1);
        }
        
        .top-bar-actions {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .cart-btn {
            position: relative;
            padding: 8px 14px;
            background: rgba(255,255,255,0.1);
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .cart-btn:hover { background: rgba(255,255,255,0.2); }
        
        .cart-btn .badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background: var(--success);
            font-size: 11px;
            padding: 2px 6px;
            border-radius: 10px;
        }
        
        /* Bottom Bar */
        .bottom-bar {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            height: auto;
            min-height: 50px;
            background: var(--bg-dark);
            backdrop-filter: blur(10px);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-wrap: wrap;
            gap: 20px;
            padding: 12px 20px;
            z-index: 100;
            border-top: 1px solid var(--border);
        }
        
        .bottom-bar a {
            color: var(--text-muted);
            font-size: 13px;
            transition: color 0.3s;
        }
        
        .bottom-bar a:hover { color: white; }
        
        .bottom-bar span { color: var(--text-muted); font-size: 13px; }
        
        /* Main Layout */
        .main-layout {
            display: flex;
            margin-top: 60px;
            margin-bottom: 60px;
            min-height: calc(100vh - 120px);
        }
        
        /* Left Sidebar */
        .left-sidebar {
            width: 280px;
            background: var(--bg-dark);
            backdrop-filter: blur(10px);
            padding: 20px;
            position: fixed;
            top: 60px;
            bottom: 60px;
            overflow-y: auto;
            border-right: 1px solid var(--border);
        }
        
        .sidebar-section {
            margin-bottom: 25px;
        }
        
        .sidebar-section h4 {
            color: var(--success);
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 12px;
            padding-bottom: 8px;
            border-bottom: 1px solid var(--border);
        }
        
        .sidebar-section a {
            display: block;
            padding: 10px 12px;
            color: var(--text-muted);
            font-size: 14px;
            border-radius: 6px;
            transition: all 0.3s;
            margin-bottom: 4px;
        }
        
        .sidebar-section a:hover {
            background: rgba(255,255,255,0.1);
            color: white;
        }
        
        .sidebar-section a .price {
            float: right;
            color: var(--success);
            font-weight: 600;
        }
        
        /* Right Content */
        .right-content {
            margin-left: 280px;
            flex: 1;
            padding: 20px;
        }
        
        /* Hero */
        .hero {
            background: var(--bg-dark);
            backdrop-filter: blur(10px);
            border-radius: 16px;
            padding: 30px;
            text-align: center;
            margin-bottom: 20px;
            border: 1px solid var(--border);
        }
        
        .hero h1 {
            font-size: 32px;
            margin-bottom: 10px;
        }
        
        .hero p {
            color: var(--text-muted);
            font-size: 15px;
            max-width: 500px;
            margin: 0 auto 15px;
        }
        
        /* Buttons */
        .btn {
            display: inline-block;
            padding: 14px 28px;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .btn-buy {
            background: var(--success);
            color: white;
        }
        
        .btn-buy:hover {
            background: #219f45;
            transform: translateY(-2px);
        }
        
        .btn-secondary {
            background: var(--secondary);
            color: white;
        }
        
        .btn-secondary:hover {
            background: #e65c00;
        }
        
        .btn-outline {
            background: transparent;
            border: 2px solid var(--success);
            color: var(--success);
        }
        
        .btn-outline:hover {
            background: var(--success);
            color: white;
        }
        
        /* Product Cards */
        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: 15px;
        }
        
        .product-card {
            background: var(--bg-dark);
            backdrop-filter: blur(10px);
            border-radius: 10px;
            overflow: hidden;
            border: 1px solid var(--border);
            transition: all 0.3s;
        }
        
        .product-card:hover {
            border-color: var(--success);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        
        .product-card-header {
            padding: 15px;
            text-align: center;
        }
        
        .product-card-header .icon {
            font-size: 32px;
            margin-bottom: 8px;
        }
        
        .product-card-header h3 {
            font-size: 16px;
            margin-bottom: 4px;
        }
        
        .product-card-header .price {
            font-size: 20px;
            color: var(--success);
            font-weight: 700;
        }
        
        .product-card-header .price span {
            font-size: 12px;
            color: var(--text-muted);
        }
        
        .product-card-features {
            padding: 0 15px;
        }
        
        .product-card-features ul {
            list-style: none;
        }
        
        .product-card-features li {
            padding: 6px 0;
            font-size: 12px;
            color: var(--text-muted);
            border-bottom: 1px solid var(--border);
        }
        
        .product-card-features li::before {
            content: '✓ ';
            color: var(--success);
        }
        
        .product-card-actions {
            padding: 12px;
            display: flex;
            gap: 8px;
        }
        
        .product-card-actions .btn {
            flex: 1;
            text-align: center;
            padding: 10px;
            font-size: 13px;
        }
        
        /* Badges */
        .badge-tag {
            position: absolute;
            top: 10px;
            right: 10px;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
        }
        
        .badge-popular { background: var(--secondary); color: white; }
        .badge-best { background: var(--success); color: white; }
        .badge-new { background: #6f42c1; color: white; }
        
        /* Agent Demo */
        .agent-demo {
            background: var(--bg-dark);
            backdrop-filter: blur(10px);
            border-radius: 10px;
            padding: 20px;
            border: 1px solid var(--border);
            margin-bottom: 20px;
        }
        
        .agent-demo h3 {
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 16px;
        }
        
        .agent-demo h3 .status {
            width: 10px;
            height: 10px;
            background: var(--success);
            border-radius: 50%;
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        @keyframes blink-green {
            0%, 100% { opacity: 1; text-shadow: 0 0 5px #28a745; }
            50% { opacity: 0.6; text-shadow: 0 0 15px #28a745; }
        }
        
        .agent-active-blink {
            animation: blink-green 2s ease-in-out infinite;
        }
        
        .agent-messages {
            height: 200px;
            background: rgba(0,0,0,0.3);
            border-radius: 8px;
            padding: 15px;
            overflow-y: auto;
            margin-bottom: 15px;
        }
        
        .agent-message {
            margin-bottom: 12px;
            display: flex;
            gap: 10px;
        }
        
        .agent-message.user {
            flex-direction: row-reverse;
        }
        
        .agent-message .avatar {
            width: 32px;
            height: 32px;
            background: var(--primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }
        
        .agent-message.user .avatar { background: var(--success); }
        
        .agent-message .bubble {
            background: rgba(255,255,255,0.1);
            padding: 10px 14px;
            border-radius: 12px;
            max-width: 70%;
            font-size: 14px;
        }
        
        .agent-input {
            display: flex;
            gap: 10px;
        }
        
        .agent-input input {
            flex: 1;
            padding: 12px 16px;
            background: rgba(0,0,0,0.3);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: white;
            font-size: 14px;
        }
        
        .agent-input input:focus {
            outline: none;
            border-color: var(--success);
        }
        
        /* Contact Form */
        .contact-form {
            background: var(--bg-dark);
            backdrop-filter: blur(10px);
            border-radius: 12px;
            padding: 30px;
            border: 1px solid var(--border);
            max-width: 600px;
            margin: 0 auto;
        }
        
        .contact-form h3 { margin-bottom: 20px; }
        
        .form-group { margin-bottom: 15px; }
        
        .form-group label {
            display: block;
            margin-bottom: 6px;
            font-size: 14px;
            color: var(--text-muted);
        }
        
        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 12px 16px;
            background: rgba(0,0,0,0.3);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: white;
            font-size: 14px;
            font-family: inherit;
        }
        
        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--success);
        }
        
        /* Cart Section */
        .page { display: none; }
        .page.active { display: block; }
        
        .cart-items {
            background: var(--bg-dark);
            border-radius: 12px;
            padding: 20px;
            border: 1px solid var(--border);
        }
        
        .cart-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 0;
            border-bottom: 1px solid var(--border);
        }
        
        .cart-item:last-child { border-bottom: none; }
        
        .cart-total {
            text-align: right;
            padding: 20px 0;
            font-size: 24px;
        }
        
        .cart-total span { color: var(--success); font-weight: 700; }
        
        /* Checkout */
        .checkout-crypto {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 15px;
            margin: 20px 0;
        }
        
        .crypto-option {
            background: rgba(255,255,255,0.05);
            border: 2px solid var(--border);
            border-radius: 10px;
            padding: 15px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .crypto-option:hover, .crypto-option.selected {
            border-color: var(--success);
            background: rgba(40, 167, 69, 0.1);
        }
        
        .crypto-option .icon { font-size: 24px; margin-bottom: 5px; }
        .crypto-option h5 { font-size: 14px; margin-bottom: 5px; }
        .crypto-option .rate { font-size: 12px; color: var(--text-muted); }
        
        .payment-box {
            background: var(--bg-dark);
            border-radius: 12px;
            padding: 30px;
            border: 1px solid var(--border);
            text-align: center;
            max-width: 400px;
            margin: 20px auto;
        }
        
        .payment-address {
            background: rgba(0,0,0,0.3);
            padding: 15px;
            border-radius: 8px;
            word-break: break-all;
            font-family: monospace;
            margin: 15px 0;
            font-size: 13px;
        }
        
        /* FAQ */
        .faq-item {
            background: var(--bg-dark);
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 10px;
            border: 1px solid var(--border);
        }
        
        .faq-item h5 { color: var(--success); margin-bottom: 8px; font-size: 14px; }
        .faq-item p { color: var(--text-muted); font-size: 13px; }
        
        /* Team */
        .team-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 12px;
        }
        
        .team-member {
            background: var(--bg-dark);
            border-radius: 8px;
            padding: 15px;
            text-align: center;
            border: 1px solid var(--border);
            transition: all 0.3s;
        }
        
        .team-member:hover {
            transform: translateY(-2px);
            border-color: var(--success);
        }
        
        .team-member .avatar {
            width: 45px;
            height: 45px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border-radius: 50%;
            margin: 0 auto 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }
        
        .team-member h5 { font-size: 14px; margin-bottom: 5px; }
        .team-member p { font-size: 12px; color: var(--text-muted); }
        
        /* Section Titles */
        .section-title { 
            font-size: 22px; 
            margin-bottom: 15px; 
            margin-top: 25px;
            padding-bottom: 8px;
            border-bottom: 1px solid var(--border);
        }
        
        /* External Links */
        .external-links {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 12px;
            margin-top: 12px;
        }
        
        .external-link-card {
            background: var(--bg-dark);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 15px;
            transition: all 0.3s;
            cursor: pointer;
        }
        
        .external-link-card:hover {
            border-color: var(--success);
            transform: translateY(-3px);
        }
        
        .external-link-card h4 {
            color: var(--success);
            margin-bottom: 8px;
        }
        
        .external-link-card p {
            color: var(--text-muted);
            font-size: 13px;
        }
        
        /* Mobile */
        @media (max-width: 1100px) {
            .left-sidebar { display: none; }
            .right-content { margin-left: 0; }
        }
        
        @media (max-width: 900px) {
            .top-bar-nav { display: none; }
            .checkout-crypto { grid-template-columns: repeat(3, 1fr); }
        }
        
        @media (max-width: 600px) {
            .hero { padding: 30px 20px; }
            .hero h1 { font-size: 28px; }
            .product-grid { grid-template-columns: 1fr; }
            .bottom-bar { flex-direction: column; gap: 10px; height: auto; }
            .checkout-crypto { grid-template-columns: repeat(2, 1fr); }
        }
    </style>
</head>
<body>
    <!-- Top Bar -->
    <nav class="top-bar">
        <div class="top-bar-logo">
            <span>🤖</span>
            <span>AGI Company</span>
        </div>
        <div class="top-bar-nav">
            <a href="index.html#" onclick="showPage('home')" class="active">Home</a>
            <a href="index.html#" onclick="showPage('shop')">Secretaries</a>
            <a href="index.html#" onclick="showPage('software')">Apps</a>
            <a href="index.html#" onclick="showPage('agents')">Agents</a>
            <a href="index.html#" onclick="showPage('services')">Services</a>
            <a href="index.html#" onclick="showPage('about')">About</a>
            <a href="index.html#" onclick="showPage('contact')">Contact</a>
            <a href="index.html#" onclick="showPage('faq')">FAQ</a>
        </div>
        <div class="top-bar-actions">
            <div class="cart-btn" onclick="showPage('cart')">
                🛒 Cart
                <span class="badge" id="cart-badge">0</span>
            </div>
        </div>
    </nav>
    
    <!-- Bottom Bar -->
    <div class="bottom-bar">
        <a href="mailto:Sales@myl0nr0s.cloud">📧 Sales</a>
        <a href="mailto:Support@myl0nr0s.cloud">💬 Support</a>
        <a href="mailto:Jobs@myl0nr0s.cloud">💼 Jobs</a>
        <a href="mailto:Legal@myl0nr0s.cloud">⚖️ Legal</a>
        <span>📞 <strong>415-571-9724</strong></span>
        <a href="index.html#" onclick="showPage('agents')">🌐 Live Agents</a>
        <a href="index.html#" onclick="showPage('payment')">💳 Payment</a>
    </div>
    
    <!-- Main Layout -->
    <div class="main-layout">
        <!-- Left Sidebar -->
        <aside class="left-sidebar">
            <div class="sidebar-section">
                <h4>🤖 Secretaries</h4>
                <a href="index.html#" onclick="showPage('shop')">Clerk <span class="price">$99</span></a>
                <a href="index.html#" onclick="showPage('shop')">Concierge <span class="price">$199</span></a>
                <a href="index.html#" onclick="showPage('shop')">Ledger <span class="price">$249</span></a>
                <a href="index.html#" onclick="showPage('shop')">Greet <span class="price">$249</span></a>
                <a href="index.html#" onclick="showPage('shop')">Closeter <span class="price">$399</span></a>
                <a href="index.html#" onclick="showPage('shop')">Executive <span class="price">$599</span></a>
            </div>
            <div class="sidebar-section">
                <h4>⚙️ Skills</h4>
                <a href="index.html#" onclick="showPage('software')">Health Monitor <span class="price">$49</span></a>
                <a href="index.html#" onclick="showPage('software')">Cron Scheduler <span class="price">$39</span></a>
                <a href="index.html#" onclick="showPage('software')">Wallet Payment <span class="price">$59</span></a>
                <a href="index.html#" onclick="showPage('software')">Store Integration <span class="price">$79</span></a>
            </div>
        </aside>
        
        <!-- Right Content -->
        <main class="right-content">
            <!-- Home Page -->
            <div id="page-home" class="page active">
                <div class="hero">
                    <h1>Welcome to AGI Company</h1>
                    <p>Intelligent AI agents, secretaries, skills, and apps for your business. Powered by cutting-edge autonomous technology.</p>
                    <button class="btn btn-buy" style="padding: 15px 40px; font-size: 16px;" onclick="showPage('shop')">🛍️ Browse Products</button>
                </div>
                
                <div class="agent-demo">
                    <h3>🤖 Try Our Live Agent <span class="status"></span></h3>
                    <div class="agent-messages" id="agent-messages-home">
                        <div class="agent-message">
                            <div class="avatar">🤖</div>
                            <div class="bubble">Hello! I'm your AGI assistant. Ask me anything about our products!</div>
                        </div>
                    </div>
                    <div class="agent-input">
                        <input type="text" id="agent-input-home" placeholder="Type your question..." onkeypress="handleAgentHome(event)">
                        <button class="btn btn-buy" onclick="sendAgentHome()">Send</button>
                    </div>
                </div>
            </div>
            
            <!-- Shop Page (Secretaries) -->
            <div id="page-shop" class="page">
                <h2 class="section-title">🤖 AI Secretaries</h2>
                <div class="product-grid" id="secretaries-grid"></div>
            </div>
            
            <!-- Software Page (Skills + Apps) -->
            <div id="page-software" class="page">
                <h2 class="section-title">⚙️ Skills & Apps</h2>
                <div class="product-grid" id="software-grid"></div>
                
                <h2 class="section-title" style="margin-top: 40px;">📱 External Services</h2>
                <div class="external-links">
                    <a href="index.html#" onclick="showPage('dusty')" class="external-link-card">
                        <h4>💰 Dusty Wallet</h4>
                        <p>Crypto dust consolidation bot</p>
                    </a>
                    <a href="index.html#" onclick="showPage('aocros')" class="external-link-card">
                        <h4>🤖 AOCROS</h4>
                        <p>Autonomous robotics system</p>
                    </a>
                    <a href="index.html#" onclick="showPage('reggiestarr')" class="external-link-card">
                        <h4>🖥️ ReggieStarr</h4>
                        <p>POS systems & hardware</p>
                    </a>
                    <a href="index.html#" onclick="showPage('pocketclaw')" class="external-link-card">
                        <h4>📱 Pocket Claw</h4>
                        <p>AI assistant on Android</p>
                    </a>
                </div>
            </div>
            
            <!-- Services Page -->
            <div id="page-services" class="page">
                <h2 class="section-title">🛠️ Services</h2>
                <div class="product-grid" id="services-grid"></div>
                
                <h2 class="section-title" style="margin-top: 40px;">📋 More Services</h2>
                <div class="external-links">
                    <a href="index.html#" onclick="showPage('cream')" class="external-link-card">
                        <h4>🥛 CREAM</h4>
                        <p>Real Estate CRM App ($699 + $99/yr)</p>
                    </a>
                    <a href="index.html#" onclick="showPage('contact')" class="external-link-card">
                        <h4>🎯 Custom Agents</h4>
                        <p>Tailored AI solutions</p>
                    </a>
                    <a href="index.html#" onclick="showPage('contact')" class="external-link-card">
                        <h4>🔧 Integration</h4>
                        <p>System integration services</p>
                    </a>
                    <a href="index.html#" onclick="showPage('contact')" class="external-link-card">
                        <h4>📚 Training</h4>
