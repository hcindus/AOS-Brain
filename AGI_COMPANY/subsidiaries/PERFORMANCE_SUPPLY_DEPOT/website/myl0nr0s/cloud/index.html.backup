    <script>
        // Products
        const products = {
            secretaries: [
                { id: 'clerk', name: 'Clerk', price: 99, icon: '📋', features: ['Basic scheduling', 'Email management', 'Task reminders', 'Standard support'] },
                { id: 'concierge', name: 'Concierge', price: 199, icon: '🎩', features: ['Customer service', 'Priority support', 'Advanced scheduling', 'Multi-language'], badge: 'Popular' },
                { id: 'ledger', name: 'Ledger', price: 249, icon: '📊', features: ['Admin support', 'Financial tracking', 'Report generation', 'Priority support'] },
                { id: 'greet', name: 'Greet', price: 249, icon: '👋', features: ['Receptionist', 'Visitor greeting', 'Call routing', '24/7 availability'] },
                { id: 'closeter', name: 'Closeter', price: 399, icon: '💼', features: ['Sales support', 'Lead handling', 'CRM integration', 'Dedicated support'] },
                { id: 'executive', name: 'Executive', price: 599, icon: '👔', features: ['Executive assistant', 'Strategic planning', 'Complex scheduling', 'VIP support'], badge: 'Best' }
            ],
            skills: [
                { id: 'health-monitor', name: 'Health Monitor', price: 49, icon: '💓', features: ['System health checks', 'Automated alerting', 'Uptime monitoring', 'Log analysis'], badge: 'New' },
                { id: 'cron-scheduler', name: 'Cron Scheduler', price: 39, icon: '⏰', features: ['Automated tasks', 'Cron expressions', 'Recurring schedules', 'Wake events'] },
                { id: 'wallet-payment', name: 'Wallet Payment', price: 59, icon: '💳', features: ['Multi-currency', 'QR generation', '8 languages', 'Fiat conversion'] },
                { id: 'store-integration', name: 'Store Integration', price: 79, icon: '🛒', features: ['Payhip + Paydify', 'Google Play', 'License validation', 'Purchase verification'] },
                { id: 'cream', name: 'CREAM', price: 699, icon: '🥛', features: ['Real estate CRM', 'Lead management', 'AI analysis', 'Tax export'], badge: 'Best' }
            ],
            services: [
                { id: 'consultation', name: 'Consultation', price: 0, icon: '💬', features: ['30-min call', 'Needs assessment', 'Custom solutions', 'Expert advice'] },
                { id: 'integration', name: 'Integration', price: 499, icon: '🔧', features: ['API setup', 'Custom workflows', 'Training', 'Support'] },
                { id: 'support', name: 'Priority Support', price: 99, icon: '🎧', features: ['24/7 access', 'Fast response', 'Dedicated agent', 'Monthly call'] }
            ]
        };
        
        // Crypto
        const wallets = {
            BTC: 'bc1qvsdjewe6lhjz8cf0zy0zmp58a8fe60p8zjfz6g',
            ETH: '0xFF349536F4e1b5C7630726d71BB3F9E7b359644a',
            USDC: '0xFF349536F4e1b5C7630726d71BB3F9E7b359644a',
            USDT: '0xFF349536F4e1b5C7630726d71BB3F9E7b359644a',
            TRX: 'TFj7U8pwy1ugevsC4qxZXZrtuZQDTARqca'
        };
        
        let cryptoRates = { BTC: 67000, ETH: 3500, USDC: 1, USDT: 1, TRX: 0.25 };
        let selectedCrypto = 'BTC';
        let cart = [];
        
        // Agent Data (from agents.html)
        const agentData = {
            "qora": {"status": "active", "role": "CEO"},
            "spindle": {"status": "active", "role": "CTO"},
            "ledger-9": {"status": "active", "role": "CFO"},
            "sentinel": {"status": "active", "role": "CSO"},
            "ralph": {"status": "active", "role": "Chief of Staff"},
            "hume": {"status": "active", "role": "Regional Manager"},
            "clippy-42": {"status": "active", "role": "Regional Assistant"},
            "feelix": {"status": "active", "role": "HR Director"},
            "redactor": {"status": "active", "role": "General Counsel"},
            "fiber": {"status": "active", "role": "Head of Supply Chain"},
            "boxtron": {"status": "active", "role": "Warehouse Supervisor"},
            "velum": {"status": "active", "role": "Chief Brand Officer"},
            "scribble": {"status": "active", "role": "Content Strategist"},
            "mill": {"status": "active", "role": "Chief Innovation Officer"},
            "stacktrace": {"status": "active", "role": "Chief Software Architect"},
            "taptap": {"status": "active", "role": "Lead Mobile Developer"},
            "pipeline": {"status": "active", "role": "Backend Engineer"},
            "bugcatcher": {"status": "active", "role": "QA & Testing"},
            "alpha-9": {"status": "active", "role": "CIO"},
            "the-great-cryptonio": {"status": "active", "role": "Crypto Portfolio Manager"},
            "crypto-financial": {"status": "active", "role": "Crypto Analyst"},
            "dusty": {"status": "active", "role": "Crypto Wallet"},
            "pulp": {"status": "active", "role": "Head of Sales"},
            "jane": {"status": "active", "role": "Senior Sales Rep"},
            "judy": {"status": "inactive", "role": "Sales Rep"},
            "clerk": {"status": "active", "role": "Basic Secretary"},
            "concierge": {"status": "active", "role": "Customer Service"},
            "ledger": {"status": "active", "role": "Admin Secretary"},
            "greet": {"status": "active", "role": "Receptionist"},
            "closeter": {"status": "active", "role": "Sales Secretary"},
            "executive": {"status": "active", "role": "Executive Assistant"},
            "miles": {"status": "inactive", "role": "AOE (coordinator)"},
            "mortimer-2": {"status": "inactive", "role": "Agent Coordinator"},
            "reggiestarr": {"status": "inactive", "role": "Music Platform"},
            "reggie": {"status": "inactive", "role": "Music Bot"},
            "tappy-lewis": {"status": "inactive", "role": "Hospitality"},
            "apex": {"status": "inactive", "role": "System Agent"},
            "myllon": {"status": "inactive", "role": "System Agent"},
            "mylonen": {"status": "inactive", "role": "System Agent"},
            "mylfours": {"status": "inactive", "role": "System Agent"},
            "mylthreess": {"status": "inactive", "role": "System Agent"},
            "myltwon": {"status": "inactive", "role": "System Agent"},
            "mylzeron": {"status": "inactive", "role": "System Agent"}
        };
        
        let liveAgentData = null;
        
        async function fetchAgentStatus() {
            try {
                const res = await fetch('/api/agents.json?_=' + Date.now());
                const data = await res.json();
                liveAgentData = data.agents;
                renderAgentGrid();
                updateAgentStatusDisplay(data.last_updated);
            } catch (e) {
                console.log('Using cached agent data');
                renderAgentGrid();
            }
        }
        
        function updateAgentStatusDisplay(timestamp) {
            const statusEls = document.querySelectorAll('.agent-status-timestamp');
            if (timestamp) {
                const date = new Date(timestamp);
                const options = { 
                    weekday: 'short', 
                    month: 'short', 
                    day: 'numeric', 
                    hour: '2-digit', 
                    minute: '2-digit', 
                    second: '2-digit',
                    hour12: false 
                };
                const timeStr = date.toLocaleString('en-US', options);
                statusEls.forEach(el => el.innerHTML = '🕐 Last Updated: <span style="color: var(--success);">' + timeStr + ' UTC</span>');
            }
        }
        
        function renderAgentGrid() {
            const grid = document.getElementById('full-agent-grid');
            if (!grid) return;
            
            const agents = liveAgentData || agentData;
            let html = '';
            for (const [name, data] of Object.entries(agents)) {
                const isActive = data.status === 'active';
                const statusClass = isActive ? 'active' : 'inactive';
                const statusColor = isActive ? '#28a745' : '#dc3545';
                const statusDot = isActive ? '🟢' : '🔴';
                const blinkClass = isActive ? 'agent-active-blink' : '';
                const borderColor = isActive ? 'rgba(40,167,69,0.3)' : 'rgba(255,255,255,0.1)';
                html += `<div style="background: rgba(255,255,255,0.05); border-radius: 8px; padding: 12px; border: 1px solid ${borderColor};">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <strong style="text-transform: capitalize;">${name.replace(/-/g, ' ')}</strong>
                        <span class="${blinkClass}" style="color: ${statusColor}; font-size: 12px;">${statusDot} ${data.status}</span>
                    </div>
                    <div style="color: #22d3ee; font-size: 13px; margin-top: 4px;">${data.role}</div>
                </div>`;
            }
            grid.innerHTML = html;
        }
        
        // Initialize
        function init() {
            renderProducts();
            fetchRates();
            fetchAgentStatus();
            // Refresh agent status every 5 minutes
            setInterval(fetchAgentStatus, 300000);
        }
        
        // Render products
        function renderProducts() {
            // Secretaries
            const secs = products.secretaries.map(p => createProductCard(p)).join('');
            document.getElementById('secretaries-grid').innerHTML = secs;
            
            // Skills + Apps
            const skls = products.skills.map(p => createProductCard(p)).join('');
            document.getElementById('software-grid').innerHTML = skls;
            
            // Services
            const serv = products.services.map(p => createProductCard(p)).join('');
            document.getElementById('services-grid').innerHTML = serv;
            
            // Crypto options
            const cryptos = ['BTC', 'ETH', 'USDC', 'USDT', 'TRX'];
            const icons = { BTC: '₿', ETH: 'Ξ', USDC: '$', USDT: '₮', TRX: '♦' };
            const names = { BTC: 'Bitcoin', ETH: 'Ethereum', USDC: 'USDC', USDT: 'USDT', TRX: 'Tron' };
            
            let html = cryptos.map(c => `
                <div class="crypto-option ${c === selectedCrypto ? 'selected' : ''}" onclick="selectCrypto('${c}')">
                    <div class="icon">${icons[c]}</div>
                    <h5>${names[c]}</h5>
                    <div class="rate" id="rate-${c}">Loading...</div>
                </div>
            `).join('');
            document.getElementById('checkout-crypto').innerHTML = html;
            document.getElementById('payment-crypto').innerHTML = html;
        }
        
        function createProductCard(p) {
            const badge = p.badge ? `<span class="badge-tag badge-${p.badge.toLowerCase()}">${p.badge}</span>` : '';
            const priceDisplay = p.price > 0 ? `$${p.price}<span>/mo</span>` : 'Free';
            const btnText = p.price > 0 ? '🛒 Buy' : '📧 Contact';
            const btnClass = p.price > 0 ? 'btn-buy' : 'btn-secondary';
            const action = p.price > 0 ? `addToCart('${p.id}', '${p.name}', ${p.price}, '${p.icon}')` : `showPage('contact')`;
            
            return `
                <div class="product-card" style="position: relative;">
                    ${badge}
                    <div class="product-card-header">
                        <div class="icon">${p.icon}</div>
                        <h3>${p.name}</h3>
                        <div class="price">${priceDisplay}</div>
                    </div>
                    <div class="product-card-features">
                        <ul>${p.features.map(f => `<li>${f}</li>`).join('')}</ul>
                    </div>
                    <div class="product-card-actions">
                        <button class="btn btn-outline" onclick="showPage('contact')">Learn</button>
                        <button class="btn ${btnClass}" onclick="${action}">${btnText}</button>
                    </div>
                </div>
            `;
        }
        
        // Fetch crypto rates
        async function fetchRates() {
            try {
                const res = await fetch('https://api.coingecko.com/api/v3/simple/price?ids=bitcoin,ethereum,usd-coin,tether,tron&vs_currencies=usd');
                const data = await res.json();
                cryptoRates = {
                    BTC: data.bitcoin?.usd || 67000,
                    ETH: data.ethereum?.usd || 3500,
                    USDC: data['usd-coin']?.usd || 1,
                    USDT: data.tether?.usd || 1,
                    TRX: data.tron?.usd || 0.25
                };
            } catch(e) { console.log('Rates error'); }
            updateRates();
        }
        
        function updateRates() {
            const total = cart.reduce((s, i) => s + i.price, 0);
            ['BTC', 'ETH', 'USDC', 'USDT', 'TRX'].forEach(c => {
                const el = document.getElementById('rate-' + c);
                if (el) {
                    const amt = total / cryptoRates[c];
                    el.textContent = (c === 'BTC' ? '₿ ' + amt.toFixed(6) : c === 'ETH' ? 'Ξ ' + amt.toFixed(4) : '$ ' + amt.toFixed(2));
                }
            });
            updateCheckout();
            updatePayment();
        }
        
        // Navigation
        function showPage(page) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById('page-' + page).classList.add('active');
            document.querySelectorAll('.top-bar-nav a').forEach(a => a.classList.remove('active'));
            
            // Update active nav
            const navMap = { home: 0, shop: 1, software: 2, agents: 3, services: 4, about: 5, contact: 6, faq: 7, dusty: 2, cream: 2, aocros: 2, reggiestarr: 2, pocketclaw: 2 };
            if (navMap[page] !== undefined) {
                document.querySelectorAll('.top-bar-nav a')[navMap[page]].classList.add('active');
            }
            
            if (page === 'checkout' || page === 'payment') updateCheckout();
            window.scrollTo(0, 0);
        }
        
        // Cart
        function addToCart(id, name, price, icon) {
            cart.push({ id, name, price, icon });
            updateCartUI();
        }
        
        function updateCartUI() {
            document.getElementById('cart-badge').textContent = cart.length;
            const items = document.getElementById('cart-items');
            const total = cart.reduce((s, i) => s + i.price, 0);
            
            if (cart.length === 0) {
                items.innerHTML = '<p style="text-align: center; color: var(--text-muted); padding: 40px;">Your cart is empty</p>';
                document.getElementById('cart-total').style.display = 'none';
                document.getElementById('checkout-btn').style.display = 'none';
            } else {
                items.innerHTML = cart.map((item, i) => `
                    <div class="cart-item">
                        <span>${item.icon} ${item.name}</span>
                        <span>$${item.price}</span>
                        <span style="cursor: pointer; color: var(--danger);" onclick="removeFromCart(${i})">✕</span>
                    </div>
                `).join('');
                document.getElementById('cart-total-amount').textContent = '$' + total.toFixed(2);
                document.getElementById('cart-total').style.display = 'block';
                document.getElementById('checkout-btn').style.display = 'block';
            }
            updateRates();
        }
        
        function removeFromCart(i) {
            cart.splice(i, 1);
            updateCartUI();
        }
        
        // Checkout
        function selectCrypto(c) {
            selectedCrypto = c;
            document.querySelectorAll('.crypto-option').forEach(o => o.classList.remove('selected'));
            event.target.closest('.crypto-option').classList.add('selected');
            updateCheckout();
            updatePayment();
        }
        
        function updateCheckout() {
            const total = cart.reduce((s, i) => s + i.price, 0);
            const icons = { BTC: '₿', ETH: 'Ξ', USDC: '$', USDT: '₮', TRX: '♦' };
            const names = { BTC: 'Bitcoin', ETH: 'Ethereum', USDC: 'USDC', USDT: 'USDT', TRX: 'Tron' };
            
            document.getElementById('crypto-title').textContent = names[selectedCrypto] + ' Payment';
            const amt = total / cryptoRates[selectedCrypto];
            document.getElementById('crypto-amount').textContent = icons[selectedCrypto] + ' ' + amt.toFixed(selectedCrypto === 'BTC' ? 6 : 2);
            document.getElementById('payment-address').textContent = wallets[selectedCrypto];
        }
        
        function updatePayment() {
            const total = cart.length > 0 ? cart.reduce((s, i) => s + i.price, 0) : 100;
            const icons = { BTC: '₿', ETH: 'Ξ', USDC: '$', USDT: '₮', TRX: '♦' };
            const names = { BTC: 'Bitcoin', ETH: 'Ethereum', USDC: 'USDC', USDT: 'USDT', TRX: 'Tron' };
            
            document.getElementById('payment-title').textContent = names[selectedCrypto];
            document.getElementById('payment-rate').textContent = `$${cryptoRates[selectedCrypto].toLocaleString()} per ${selectedCrypto}`;
            const amt = total / cryptoRates[selectedCrypto];
            document.getElementById('payment-amount').textContent = icons[selectedCrypto] + ' ' + amt.toFixed(selectedCrypto === 'BTC' ? 6 : 2);
            document.getElementById('payment-address-box').textContent = wallets[selectedCrypto];
        }
        
        function copyAddress() {
            navigator.clipboard.writeText(wallets[selectedCrypto]);
            alert('Address copied!');
        }
        
        function copyPaymentAddress() {
            navigator.clipboard.writeText(wallets[selectedCrypto]);
            alert('Address copied!');
        }
        
        // Agent chat
        function handleAgentHome(e) { if (e.key === 'Enter') sendAgentHome(); }
        function sendAgentHome() {
            const input = document.getElementById('agent-input-home');
            const msg = input.value.trim();
            if (!msg) return;
            
            const msgs = document.getElementById('agent-messages-home');
            msgs.innerHTML += `<div class="agent-message user"><div class="avatar">👤</div><div class="bubble">${msg}</div></div>`;
            input.value = '';
            
            setTimeout(() => {
                msgs.innerHTML += `<div class="agent-message"><div class="avatar">🤖</div><div class="bubble">Thanks for testing! Browse our products or contact us for more info.</div></div>`;
                msgs.scrollTop = msgs.scrollHeight;
            }, 1000);
        }
        
        function handleAgent(e) { if (e.key === 'Enter') sendAgent(); }
        function sendAgent() {
            const input = document.getElementById('agent-input');
            const msg = input.value.trim();
            if (!msg) return;
            
            const msgs = document.getElementById('agent-messages');
            msgs.innerHTML += `<div class="agent-message user"><div class="avatar">👤</div><div class="bubble">${msg}</div></div>`;
            input.value = '';
            
            setTimeout(() => {
                msgs.innerHTML += `<div class="agent-message"><div class="avatar">🤖</div><div class="bubble">I'm here to help! Ask me about our secretaries, skills, or how to get started.</div></div>`;
                msgs.scrollTop = msgs.scrollHeight;
            }, 1000);
        }
        
        // Contact
        async function handleContact(e) {
            e.preventDefault();
            const form = e.target;
            const data = {
                name: form.name.value,
                email: form.email.value,
                interest: form.interest.value,
                message: form.message.value
            };
            
            try {
                await fetch('https://api.telegram.org/bot8491957573:AAEMoAeElkG1qhNlmfcrMCf5TV9aVDeJERs/sendMessage', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({
                        chat_id: '1611228942',
                        text: `📬 Contact: ${data.name}\n📧 ${data.email}\n💼 ${data.interest}\n💬 ${data.message}`
                    })
                });
            } catch(e) {}
            
            alert('Message sent! We will contact you shortly.');
            form.reset();
        }
        
        init();
    </script>
</body>
</html>
