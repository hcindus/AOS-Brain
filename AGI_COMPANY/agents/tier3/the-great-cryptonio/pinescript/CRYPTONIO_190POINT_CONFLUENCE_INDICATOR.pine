// if longSignal
//     strategy.entry("Long", strategy.long)
//     strategy.exit("Long TP", "Long", limit=close * 1.015, stop=close * 0.985) // 1.5:1 R:R

// if shortSignal
//     strategy.entry("Short", strategy.short)
//     strategy.exit("Short TP", "Short", limit=close * 0.985, stop=close * 1.015) // 1.5:1 R:R

