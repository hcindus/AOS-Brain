// TradingView Pine Script Strategy
// R2-D2 Confluence Scoring Algorithm
// Converted from Python to Pine Script v5
// For use with Cryptonio Trading Bot signals

//@version=5
strategy("Cryptonio R2-D2 Strategy", overlay=true, initial_capital=1000, default_qty_type=strategy.percent_of_equity, default_qty_value=10)

// ═══════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════

// Confluence Threshold
confluenceThreshold = input.int(60, "Confluence Score Threshold", minval=0, maxval=190)
minConfidence = input.float(0.6, "Minimum Confidence", minval=0.0, maxval=1.0, step=0.05)

// Risk Management
atrPeriod = input.int(14, "ATR Period")
atrMultiplier = input.float(1.0, "ATR Multiplier for Stop Loss")
riskRewardRatio = input.float(1.5, "Risk/Reward Ratio")

// EMA Settings
emaFast = input.int(40, "Fast EMA Period")
emaSlow = input.int(80, "Slow EMA Period")

// Volume Profile
volumeLookback = input.int(20, "Volume Lookback Period")

// ═══════════════════════════════════════════════════════════
// SUPPORT/RESISTANCE CALCULATION (40 points max)
// ═══════════════════════════════════════════════════════════

// Pivot points
pivotHigh = ta.pivothigh(high, 5, 5)
pivotLow = ta.pivotlow(low, 5, 5)

// Recent support/resistance levels
var float resistanceLevel = na
var float supportLevel = na

if not na(pivotHigh)
    resistanceLevel := pivotHigh
    
if not na(pivotLow)
    supportLevel := pivotLow

// Distance to nearest S/R level
resistanceDistance = resistanceLevel ? (resistanceLevel - close) / close * 100 : 100
supportDistance = supportLevel ? (close - supportLevel) / close * 100 : 100

// Score based on proximity (closer = higher score)
srScore = 0.0
if close > (resistanceLevel * 0.99) and close < (resistanceLevel * 1.01)
    srScore := 40.0  // Near resistance
else if close > (supportLevel * 0.99) and close < (supportLevel * 1.01)
    srScore := 40.0  // Near support
else if resistanceDistance < 2.0 or supportDistance < 2.0
    srScore := 25.0  // Within 2%
else if resistanceDistance < 5.0 or supportDistance < 5.0
    srScore := 15.0  // Within 5%

// ═══════════════════════════════════════════════════════════
// TREND ALIGNMENT (45 points max)
// ═══════════════════════════════════════════════════════════

// EMAs
ema40 = ta.ema(close, emaFast)
ema80 = ta.ema(close, emaSlow)

// Trend alignment
trendScore = 0.0
if ema40 > ema80 and close > ema40
    trendScore := 45.0  // Strong uptrend
else if ema40 < ema80 and close < ema40
    trendScore := 45.0  // Strong downtrend
else if ema40 > ema80
    trendScore := 25.0  // Weak uptrend
else if ema40 < ema80
    trendScore := 25.0  // Weak downtrend

// Golden Cross / Death Cross detection
goldenCross = ta.crossover(ema40, ema80)
deathCross = ta.crossunder(ema40, ema80)

// ═══════════════════════════════════════════════════════════
// VOLUME PROFILE (55 points max)
// ═══════════════════════════════════════════════════════════

// Volume moving average
volMA = ta.sma(volume, volumeLookback)
volRatio = volume / volMA

// High volume node detection
isHighVolume = volRatio > 1.5

// Volume score
volumeScore = 0.0
if isHighVolume and close > open
    volumeScore := 55.0  // High volume + bullish
else if isHighVolume and close < open
    volumeScore := 55.0  // High volume + bearish
else if volRatio > 1.2
    volumeScore := 35.0  // Above average volume
else if volRatio > 1.0
    volumeScore := 20.0  // Average volume

// ═══════════════════════════════════════════════════════════
// MOMENTUM DIVERGENCE (25 points max)
// ═══════════════════════════════════════════════════════════

// RSI
rsi = ta.rsi(close, 14)

// MACD
[macdLine, signalLine, _] = ta.macd(close, 12, 26, 9)

// Divergence detection (simplified)
momentumScore = 0.0
if rsi < 30 and macdLine > signalLine
    momentumScore := 25.0  // Bullish divergence
else if rsi > 70 and macdLine < signalLine
    momentumScore := 25.0  // Bearish divergence
else if rsi > 50 and macdLine > signalLine
    momentumScore := 15.0  // Bullish momentum
else if rsi < 50 and macdLine < signalLine
    momentumScore := 15.0  // Bearish momentum

// ═══════════════════════════════════════════════════════════
// WHALE ACTIVITY (30 points max)
// ═══════════════════════════════════════════════════════════

// Large candle detection (potential whale activity)
candleSize = math.abs(close - open) / open * 100
avgCandleSize = ta.sma(candleSize, 20)

whaleScore = 0.0
if candleSize > avgCandleSize * 2.0
    whaleScore := 30.0  // Large candle = whale activity
else if candleSize > avgCandleSize * 1.5
    whaleScore := 20.0  // Above average candle
else if candleSize > avgCandleSize
    whaleScore := 10.0  // Slightly above average

// ═══════════════════════════════════════════════════════════
// CONFLUENCE SCORING
// ═══════════════════════════════════════════════════════════

totalScore = srScore + trendScore + volumeScore + momentumScore + whaleScore
maxScore = 190.0
confidence = totalScore / maxScore

// ═══════════════════════════════════════════════════════════
// SIGNAL GENERATION
// ═══════════════════════════════════════════════════════════

// ATR for risk management
atr = ta.atr(atrPeriod)

// Signal conditions
longSignal = totalScore >= confluenceThreshold and confidence >= minConfidence and close > ema40 and goldenCross
shortSignal = totalScore >= confluenceThreshold and confidence >= minConfidence and close < ema40 and deathCross

// Entry prices
longEntry = close
shortEntry = close

// Stop loss and take profit
longStop = longEntry - (atr * atrMultiplier)
longTake = longEntry + ((longEntry - longStop) * riskRewardRatio)

shortStop = shortEntry + (atr * atrMultiplier)
shortTake = shortEntry - ((shortStop - shortEntry) * riskRewardRatio)

// ═══════════════════════════════════════════════════════════
// STRATEGY EXECUTION
// ═══════════════════════════════════════════════════════════

if longSignal
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop=longStop, limit=longTake)

if shortSignal
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop=shortStop, limit=shortTake)

// ═══════════════════════════════════════════════════════════
// VISUALIZATION
// ═══════════════════════════════════════════════════════════

// Plot EMAs
plot(ema40, "EMA 40", color=color.new(color.blue, 0), linewidth=2)
plot(ema80, "EMA 80", color=color.new(color.orange, 0), linewidth=2)

// Plot S/R levels
plot(resistanceLevel, "Resistance", color=color.new(color.red, 50), style=plot.style_linebr)
plot(supportLevel, "Support", color=color.new(color.green, 50), style=plot.style_linebr)

// Background color based on score
bgcolor(totalScore >= 100 ? color.new(color.green, 90) : totalScore >= 60 ? color.new(color.yellow, 90) : color.new(color.gray, 95))

// ═══════════════════════════════════════════════════════════
// INFO PANEL
// ═══════════════════════════════════════════════════════════

var table infoPanel = table.new(position.top_right, 2, 7, bgcolor=color.new(color.black, 10), frame_color=color.gray, frame_width=1)

if barstate.islast
    table.cell(infoPanel, 0, 0, "R2-D2 Score", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 0, str.tostring(totalScore, "#.0") + "/190", text_color=totalScore >= 100 ? color.green : totalScore >= 60 ? color.yellow : color.red, text_size=size.small)
    
    table.cell(infoPanel, 0, 1, "Confidence", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 1, str.tostring(confidence * 100, "#.0") + "%", text_color=confidence >= 0.6 ? color.green : color.gray, text_size=size.small)
    
    table.cell(infoPanel, 0, 2, "S/R Score", text_color=color.gray, text_size=size.tiny)
    table.cell(infoPanel, 1, 2, str.tostring(srScore, "#.0"), text_color=color.gray, text_size=size.tiny)
    
    table.cell(infoPanel, 0, 3, "Trend Score", text_color=color.gray, text_size=size.tiny)
    table.cell(infoPanel, 1, 3, str.tostring(trendScore, "#.0"), text_color=color.gray, text_size=size.tiny)
    
    table.cell(infoPanel, 0, 4, "Volume Score", text_color=color.gray, text_size=size.tiny)
    table.cell(infoPanel, 1, 4, str.tostring(volumeScore, "#.0"), text_color=color.gray, text_size=size.tiny)
    
    table.cell(infoPanel, 0, 5, "Momentum", text_color=color.gray, text_size=size.tiny)
    table.cell(infoPanel, 1, 5, str.tostring(momentumScore, "#.0"), text_color=color.gray, text_size=size.tiny)
    
    table.cell(infoPanel, 0, 6, "Whale Score", text_color=color.gray, text_size=size.tiny)
    table.cell(infoPanel, 1, 6, str.tostring(whaleScore, "#.0"), text_color=color.gray, text_size=size.tiny)
