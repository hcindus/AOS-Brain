# Stripe iOS SDK Integration Guide

## Installation

### CocoaPods
```ruby
pod 'StripePaymentSheet', '~> 23.0'
```

### Swift Package Manager
```swift
dependencies: [
    .package(url: "https://github.com/stripe/stripe-ios.git", from: "23.0.0")
]
```

## Implementation

### 1. Configure Stripe
```swift
import StripePaymentSheet

class PaymentViewController: UIViewController {
    var paymentSheet: PaymentSheet?
    let backendCheckoutUrl = "https://your-backend.com/create-payment-intent"
    
    func configureStripe() {
        // Fetch PaymentIntent from backend
        var request = URLRequest(url: URL(string: backendCheckoutUrl)!)
        request.httpMethod = "POST"
        
        let task = URLSession.shared.dataTask(with: request) { [weak self] data, response, error in
            guard let data = data,
                  let json = try? JSONSerialization.jsonObject(with: data) as? [String: Any],
                  let clientSecret = json["clientSecret"] as? String else {
                return
            }
            
            // Configure PaymentSheet
            var configuration = PaymentSheet.Configuration()
            configuration.merchantDisplayName = "Performance Supply Depot"
            configuration.applePay = .init(merchantId: "merchant.com.yourcompany", merchantCountryCode: "US")
            
            self?.paymentSheet = PaymentSheet(
                paymentIntentClientSecret: clientSecret,
                configuration: configuration
            )
        }
        task.resume()
    }
}
```

### 2. Present PaymentSheet
```swift
func presentPaymentSheet() {
    guard let paymentSheet = paymentSheet else { return }
    
    paymentSheet.present(from: self) { [weak self] result in
        switch result {
        case .completed:
            print("Payment completed!")
        case .canceled:
            print("Payment canceled")
        case .failed(let error):
            print("Payment failed: \(error)")
        }
    }
}
```

### 3. Apple Pay Configuration
```swift
// In your Info.plist
<key&gt;com.apple.developer.in-app-payments</key&gt;
<array&gt;
    <string&gt;merchant.com.yourcompany</string&gt;
</array&gt;
```

## Backend Endpoint (Node.js Example)
```javascript
const stripe = require('stripe')('sk_test_...'); // Your secret key

app.post('/create-payment-intent', async (req, res) => {
    const paymentIntent = await stripe.paymentIntents.create({
        amount: 4999, // $49.99 in cents
        currency: 'usd',
        automatic_payment_methods: { enabled: true },
    });
    
    res.json({ clientSecret: paymentIntent.client_secret });
});
```

## Test Cards
- Success: 4242 4242 4242 4242
- Decline: 4000 0000 0000 0002
- 3D Secure: 4000 0025 0000 3155

EOF

